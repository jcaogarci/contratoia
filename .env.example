# ==========================================================
# ContratoIA — Variables de entorno
# Copia este archivo como .env.local para desarrollo
# y configura las mismas variables en Vercel (Settings → Environment Variables)
# ==========================================================

# Clave de la API de Anthropic (para redactar los contratos)
ANTHROPIC_API_KEY=sk-ant-...

# Clave secreta de Stripe (para cobrar 4,99 € por contrato)
# Empieza por sk_test_ en pruebas y sk_live_ en producción
STRIPE_SECRET_KEY=sk_test_...
